SELECT 7 AS month,
  COUNT(DISTINCT ua_july.user_id) AS monthly_active_users
FROM (
  SELECT DISTINCT user_id
  FROM user_actions
  WHERE event_date >= '2022-07-01'
    AND event_date <  '2022-08-01'
) AS ua_july
JOIN (
  SELECT DISTINCT user_id
  FROM user_actions
  WHERE event_date >= '2022-06-01'
    AND event_date <  '2022-07-01'
) AS ua_june
ON ua_july.user_id = ua_june.user_id;
